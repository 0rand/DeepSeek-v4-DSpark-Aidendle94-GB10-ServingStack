# === DragonForce (WORKER / rank 1) ===
NODE_RANK=1
HEADLESS=1
MASTER_ADDR=192.168.0.8

# Image
IMAGE=aidendle94/sparkrun-vllm-ds4-gb10:production-3.5

# Model
MODEL_PATH=deepseek-ai/DeepSeek-V4-Flash-DSpark

# Cache dirs
HF_CACHE=/home/xraan/.cache/huggingface
VLLM_CACHE=/home/xraan/.cache/vllm-ds4-dspark
TILELANG_CACHE=/home/xraan/.cache/tilelang-ds4

# RoCE devices (DragonForce CX7 — same GB10 hardware, same device names)
NCCL_IB_HCA=rocep1s0f0,roceP2p1s0f0
NCCL_SOCKET_IFNAME=enP7s7
CONTROL_IF=enP7s7
VLLM_HOST_IP=192.168.0.88

# Tuning — validated production profile
SPEC_TOKENS=3
PORT=8100
GPU_MEMORY_UTILIZATION=0.84
MAX_NUM_SEQS=8
MAX_NUM_BATCHED_TOKENS=12144
GRAPH_CAP=32
