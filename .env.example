# =============================================================================
# DS4F-DSpark-Aiden — Single Configuration File
# =============================================================================
# Copy this file to .env, edit for your cluster, then:
#
#   WORKER (start FIRST):  docker compose -f compose.yaml -f compose.worker.yaml up -d
#   HEAD   (start second): docker compose -f compose.yaml -f compose.head.yaml  up -d
#
# Or use ./start.sh (handles sync + ordering).
# =============================================================================

# --- Docker Image ---
# Aiden's sparkrun image; change tag for newer versions.
IMAGE=aidendle94/sparkrun-vllm-ds4-gb10:production-3.7

# --- Model ---
MODEL_PATH=deepseek-ai/DeepSeek-V4-Flash-DSpark
# Pin to a specific revision to avoid cache surprises when DeepSeek pushes
# a README-only update that invalidates the HF cache.
MODEL_REVISION=913f0657a874f76844e2e91cbe706dbcaceeb6d7

# The served model name your clients use (keep stable across config changes).
SERVED_MODEL_NAME=deepseek-v4-flash

# --- Cache Directories ---
# Absolute paths on each node. These are local paths — both nodes can use
# the same value if the directory structure is identical.
HF_CACHE=/home/user/.cache/huggingface
VLLM_CACHE=/home/user/.cache/vllm-ds4-dspark
TILELANG_CACHE=/home/user/.cache/tilelang-ds4

# --- RoCE Network Interfaces ---
# Find yours:
#   ibstat | grep -E 'CA|hca_id'          → HCA names
#   ip -br addr | grep <roce-subnet>      → netdev names
# Both DGX Sparks use identical CX7 NICs so these values are the same
# on both nodes if your hardware is homogenous.
NCCL_IB_HCA=rocepXsXfX,rocePXpXfX
NCCL_SOCKET_IFNAME=enpXsXfXnpX,enPXpXfXnpX
CONTROL_IF=enpXsXfXnpX

# --- Cluster IPs (RoCE / backend network) ---
MASTER_ADDR=192.168.0.1       # head node's RoCE IP — same on both nodes
HEAD_ROCE_IP=192.168.0.1      # head node's own RoCE IP (usually same as MASTER_ADDR)
WORKER_ROCE_IP=192.168.0.2    # worker node's own RoCE IP

# --- SSH (for start.sh to sync configs to the worker) ---
WORKER_SSH_TARGET=user@worker-hostname-or-ip
WORKER_DIR=/home/user/dockers/DS4F-DFlash-Aiden-3.7

# --- Serving ---
PORT=8100
TP_SIZE=2                     # tensor parallelism across 2 nodes
SPEC_TOKENS=4                 # speculative tokens (3=balanced, 5=code-heavy)

# --- Generation Defaults ---
TEMPERATURE=0.95
TOP_P=0.44

# --- GPU Memory ---
GPU_MEMORY_UTILIZATION=0.85

# --- Context & Throughput ---
MAX_MODEL_LEN=1048576
MAX_NUM_SEQS=16
MAX_NUM_BATCHED_TOKENS=8192
GRAPH_CAP=256
ASYNC_SCHED=1
